# Supabase Authentication (Public Keys used by @supabase/ssr)
# Get these from your Supabase Project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[id of your project].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="..."

# Prisma Database Connection (Secret Key)
# Get this from Supabase Project -> Settings -> Database -> Connection string
# RECOMMENDED: Use the Supavisor POOLER string (ends in :6543)
DATABASE_URL="postgresql://postgres:[your password]@db.[id of your project].supabase.co:[port]/postgres"

# Inngest (Secret Key)
# Get this from your Inngest Cloud Dashboard -> Settings -> Signing Key
INNGEST_SIGNING_KEY="YOUR SIGNING KEY"
INNGEST_EVENT_KEY="YOUR EVENT KEY"


# Youtube API Key (Secret Key)
# Get this from your Google Cloud Console -> Credentials
YOUTUBE_API_KEY="YOUR YOUTUBE API KEY"

# --- FUTURE KEYS (Add these when you implement the features) ---

# ZeroEntropy (Secret Key)
# Get this from your ZeroEntropy Dashboard/Settings
ZERO_ENTROPY_API_KEY="..."
ZERO_ENTROPY_URL="https://api.zeroentropy.dev/v1"

# LLM Provider (e.g., Anthropic Claude) (Secret Key)
# Get this from your Anthropic Dashboard/Settings
# ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"
